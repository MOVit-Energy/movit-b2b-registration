SHOPIFY_SHOP=movitenergy.myshopify.com
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...

# Klaviyo Private API key (pk_...) pro odesílání transakčních events.
KLAVIYO_PRIVATE_KEY=pk_...
# Verze Klaviyo API (revision header). Nech default, pokud nevíš.
KLAVIYO_API_REVISION=2025-04-15

# Slack Incoming Webhook pro admin notifikace o nových B2B žádostech.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

APPROVAL_TOKEN_SECRET=...

# ID existujiciho B2B katalogu (Products → Catalogs v Shopify adminu)
B2B_CATALOG_ID=gid://shopify/Catalog/...
SHOP_URL=https://movitenergy.cz

# Veřejná URL této aplikace (schvalovací odkazy /api/b2b/approve|reject).
APP_URL=https://movit-b2b-registration.vercel.app

# Povolené originy pro CORS (čárkou oddělené). Když chybí, použije se SHOP_URL.
ALLOWED_ORIGINS=https://movitenergy.cz
